---
import Layout from "../layouts/Layout.astro";
import { projectsPageContent } from "../config";
import AILabCard from "../components/AILabCard.astro";
---

<Layout seo={{title: "AI Labs | Ruthwik Arepelly", description: "Experiments Library", image: ""}}>
  <div class="max-w-4xl mx-auto px-6 mt-16 pb-32">
    <a href="/" class="text-blue-400 text-sm font-bold flex items-center gap-2 mb-10 hover:opacity-70 transition-opacity">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back to Portfolio
    </a>

    <header class="mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight mb-4">AI Labs</h1>
      <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
        AI Labs contains experimental prototypes exploring emerging AI capabilities before they become full production products.
      </p>
    </header>

    <div class="grid grid-cols-1 gap-6">
      {projectsPageContent.aiLabs.map((lab) => (
        <AILabCard {...lab} />
      ))}
    </div>
  </div>
</Layout>
