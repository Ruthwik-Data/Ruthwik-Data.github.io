---
import Layout from "../layouts/Layout.astro";
import { homePageContent, identity, skillCategories, projectsPageContent, aboutPageContent, socialLinks } from "../config";
import SocialLink from "../components/SocialLink.astro";
import ProjectCard from "../components/ProjectCard.astro";
import AILabCard from "../components/AILabCard.astro";
import ConceptCard from "../components/ConceptCard.astro";
import ResumeItem from "../components/ResumeItem.astro";
import SocialLinkBox from "../components/SocialLinkBox.astro";
import { marked } from "marked";
import ChaosToClarityDiagram from "../components/ChaosToClarityDiagram.astro";

const aboutBioFirst = aboutPageContent.about.bioFirstLine;
const aboutBioSecond = aboutPageContent.about.bioSecondLine;
const workDescription = marked.parse(aboutPageContent.work.description);
const connectDescription = marked.parse(aboutPageContent.connect.description);

// Assume the first project is the featured one if it's SugarShield
const featuredProject = projectsPageContent.projects.find(p => p.id === 'sugarshield') || projectsPageContent.projects[0];
---

<Layout seo={homePageContent.seo}>
  {/* 1. HERO SECTION */}
  <section class="mt-20 max-w-4xl mx-auto px-6 mb-32">
    <div class="flex flex-col-reverse md:flex-row gap-12 items-start opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_forwards]">
      <div class="flex-1">
        <h1 class="font-bold text-5xl md:text-6xl mb-4 tracking-tight text-white leading-[1.1]">
          Building <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">0→1 AI Products</span>
        </h1>
        <p class="text-2xl text-white font-bold mb-3 max-w-xl leading-snug">
          {homePageContent.heroBioFirstLine}
        </p>
        <p class="text-xl text-zinc-400 font-medium mb-8 leading-relaxed max-w-xl">
          {homePageContent.heroBioSecondLine}
        </p>
        <ul class="space-y-3 mb-10 max-w-xl">
          {homePageContent.heroProofPoints.map((point) => (
            <li class="flex items-start gap-3 text-zinc-400 text-[15px]">
              <span class="text-blue-500 mt-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </span>
              <span set:html={marked.parseInline(point)} class="leading-relaxed" />
            </li>
          ))}
        </ul>
        <div class="flex flex-wrap gap-4 mb-10">
          <a href="#projects" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white rounded-full font-bold transition-all shadow-lg shadow-blue-900/20 flex items-center gap-2">
            View My Work
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="flex gap-4">
          {socialLinks.map((link) => (
            <SocialLink title={link.title} url={link.url} icon={link.icon} external={link.external} />
          ))}
        </div>
      </div>
      <div class="relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-emerald-600 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative w-[140px] h-[140px] md:w-[180px] md:h-[180px] bg-zinc-900 rounded-2xl overflow-hidden border border-white/10">
           <img src={identity.logo} alt={identity.name} class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  {/* 1b. IMPACT / CREDIBILITY */}
  <section class="max-w-4xl mx-auto px-6 mb-24 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.15s_forwards]">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {[
        { icon: "📦", stat: "5 AI Products Shipped", sub: "From 0→1 in NLP, Vision, and Agentic systems" },
        { icon: "⚙️", stat: "RAG · Agents · Vision", sub: "Built with GPT-4o, vector search, and eval pipelines" },
        { icon: "📊", stat: "Evaluation-First", sub: "Created ground-truth datasets for every shipped system" },
      ].map((item) => (
        <div class="flex items-start gap-4 p-5 bg-zinc-900/50 border border-white/5 rounded-2xl hover:border-blue-500/20 transition-colors">
          <span class="text-2xl shrink-0">{item.icon}</span>
          <div>
            <p class="text-sm font-bold text-white leading-snug mb-1">{item.stat}</p>
            <p class="text-xs text-zinc-500 leading-relaxed">{item.sub}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* 2. FEATURED PROJECT */}
  <section class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.2s_forwards]">
    <h2 class="font-bold text-3xl text-white mb-8">Featured Case Study</h2>
    <a href={`/projects/${featuredProject.id}`} class="block group relative bg-zinc-900/40 border border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all hover:scale-[1.01] hover:shadow-xl hover:shadow-blue-900/10">
       <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
         <div class="p-8 md:p-12 flex flex-col justify-center">
            <span class="text-blue-400 font-bold uppercase tracking-[0.2em] text-xs mb-4 block">Flagship Product</span>
            <h3 class="text-3xl font-bold text-white mb-4 group-hover:text-blue-400 transition-colors">{featuredProject.title}</h3>
            <p class="text-zinc-400 text-lg mb-8 leading-relaxed">{featuredProject.shortProblem} {featuredProject.outcome}</p>
            <div class="flex items-center gap-2 text-sm font-bold text-white uppercase tracking-widest group-hover:text-blue-400 transition-colors">
              Read Deep Dive <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
         </div>
         <div class="bg-zinc-900 relative border-t md:border-t-0 md:border-l border-white/5 order-first md:order-last min-h-[300px]">
           <img src={featuredProject.image} alt={featuredProject.title} class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" />
         </div>
       </div>
    </a>
  </section>

  {/* 3. PROJECTS (ALL PROJECTS GRID) */}
  <section id="projects" class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.3s_forwards]">
    <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h2 class="font-bold text-3xl text-white mb-2">AI Products & Systems</h2>
        <p class="text-zinc-500 text-lg leading-relaxed">Real AI products, prototypes, and experiments solving real-world problems.</p>
      </div>
      <div class="flex flex-wrap gap-4 text-xs font-bold uppercase tracking-widest bg-zinc-900/50 p-4 rounded-2xl border border-white/5">
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-emerald-400"></span><span class="text-zinc-400">SHIPPED PRODUCT</span></div>
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-blue-400"></span><span class="text-zinc-400">PROTOTYPE</span></div>
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-purple-400"></span><span class="text-zinc-400">SYSTEM DESIGN</span></div>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6">
      {projectsPageContent.projects.filter((p) => !p.hideFromGrid).map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>

  {/* 4. AI LABS */}
  <section class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.4s_forwards]">
    <div class="mb-12 flex justify-between items-end">
      <div>
        <h2 class="font-bold text-3xl text-white mb-2">AI Labs</h2>
        <p class="text-zinc-500 text-lg leading-relaxed">Experiments exploring emerging AI capabilities and product ideas.</p>
      </div>
      <a href="/labs" class="text-blue-400 text-sm font-bold hover:underline hidden sm:block">All Labs →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projectsPageContent.aiLabs.map((lab) => (
        <AILabCard {...lab} />
      ))}
    </div>
  </section>

  {/* 4b. CONCEPTS & EARLY-STAGE EXPERIMENTS */}
  <section class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.45s_forwards]">
    <div class="mb-12 flex justify-between items-end">
      <div>
        <h2 class="font-bold text-3xl text-white mb-2">Concepts & Early-Stage Experiments</h2>
        <p class="text-zinc-500 text-lg leading-relaxed">Idea-stage projects where I explored problems, hypotheses, and product directions before committing to full builds.</p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projectsPageContent.concepts.map((concept) => (
        <ConceptCard {...concept} />
      ))}
    </div>
  </section>

  {/* 5. SKILLS */}
  <section class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.5s_forwards]">
     <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {skillCategories.map((category) => (
        <div class="p-8 bg-zinc-900/30 border border-white/5 rounded-3xl backdrop-blur-sm">
          <h2 class="text-[10px] font-bold text-blue-400 mb-6 uppercase tracking-[0.2em]">{category.title}</h2>
          <div class="flex flex-wrap gap-2.5">
            {category.skills.map((skill) => (
              <span class="text-sm text-zinc-400 font-medium px-3 py-1 bg-white/5 rounded-full border border-white/5">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* 5b. AI SYSTEMS I WORK WITH */}
  <section class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.55s_forwards]">
    <h2 class="font-bold text-3xl text-white mb-2">AI Systems I Work With</h2>
    <p class="text-zinc-500 text-lg mb-8 leading-relaxed">The AI primitives I design with, evaluate, and ship into products.</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {[
        { label: "RAG Pipelines", icon: "🔍", color: "blue" },
        { label: "Vision + LLM Systems", icon: "👁️", color: "purple" },
        { label: "Agent Workflows", icon: "🤖", color: "emerald" },
        { label: "LLM Evaluation Frameworks", icon: "📋", color: "amber" },
        { label: "Vector Search Systems", icon: "🗄️", color: "blue" },
        { label: "Human-in-the-Loop AI", icon: "🔁", color: "emerald" },
      ].map((item) => (
        <div class={`flex items-center gap-3 p-4 rounded-2xl border bg-zinc-900/50 border-white/5 hover:border-${item.color}-500/30 transition-colors group`}>
          <span class="text-xl shrink-0">{item.icon}</span>
          <span class="text-sm font-semibold text-zinc-300 group-hover:text-white transition-colors leading-tight">{item.label}</span>
        </div>
      ))}
    </div>
  </section>

  {/* 6. PROFESSIONAL EXPERIENCE */}
  <section class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.6s_forwards]">
    <h2 class="font-bold text-3xl text-white mb-2">Professional Experience</h2>
    <div class="mb-10 text-zinc-400 text-lg italic">
      <Fragment set:html={workDescription} />
    </div>
    <div class="grid grid-cols-1 group gap-x-6 gap-y-0 relative border-l border-white/10 pl-8 ml-4">
      <div class="absolute top-0 bottom-0 left-[-1px] w-[2px] bg-gradient-to-b from-blue-500/50 via-emerald-500/20 to-transparent"></div>
      {aboutPageContent.work.items.map((item) => <ResumeItem {...item} />)}
    </div>
  </section>

  {/* 7. ABOUT */}
  <section id="about" class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.7s_forwards]">
    <h2 class="font-bold text-3xl text-white mb-8">About Me</h2>
    <div class="flex flex-col md:flex-row gap-12 items-center">
      <div class="flex-1 text-zinc-300 leading-relaxed text-lg space-y-6">
        <p class="font-bold text-2xl text-white leading-snug">{aboutBioFirst}</p>
        <p class="text-lg text-zinc-400 leading-relaxed">{aboutBioSecond}</p>
      </div>
      <div class="w-full md:w-[420px] shrink-0">
        <ChaosToClarityDiagram />
      </div>
    </div>
  </section>

  {/* 7b. BEYOND WORK */}
  <section class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.75s_forwards]">
    <div class="mb-10">
      <h2 class="font-bold text-3xl text-white mb-3">Beyond Work</h2>
      <p class="text-zinc-500 text-lg leading-relaxed max-w-2xl">
        Outside of building AI products, I enjoy reading about startups, product strategy, behavioral design, and decision-making. These books have influenced how I think about building products and understanding users.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {[
        { title: "Zero to One", author: "Peter Thiel", cover: "/books/zero-to-one.jpg" },
        { title: "The Mom Test", author: "Rob Fitzpatrick", cover: "/books/the-mom-test.jpg" },
        { title: "Hooked", author: "Nir Eyal", cover: "/books/hooked.jpg" },
        { title: "The Psychology of Money", author: "Morgan Housel", cover: "/books/psychology-of-money.jpg" },
        { title: "Steve Jobs", author: "Walter Isaacson", cover: "/books/steve-jobs.jpg" },
      ].map((book) => (
        <div class="group flex gap-5 items-start p-5 bg-zinc-900/50 border border-white/5 rounded-2xl hover:border-white/15 hover:scale-[1.02] hover:shadow-xl hover:shadow-black/40 transition-all duration-300">
          <div class="w-16 shrink-0 rounded-lg overflow-hidden shadow-lg shadow-black/50 border border-white/10">
            <img
              src={book.cover}
              alt={`${book.title} by ${book.author}`}
              loading="lazy"
              class="w-full aspect-[2/3] object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="flex flex-col justify-center min-h-[64px]">
            <h3 class="font-bold text-white text-sm leading-snug mb-1 group-hover:text-blue-300 transition-colors">{book.title}</h3>
            <p class="text-xs text-zinc-500">{book.author}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* 8. BLOG (STRATEGY PIECES) */}
  <section class="max-w-4xl mx-auto px-6 mb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.8s_forwards]">
    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="font-bold text-3xl text-white mb-2">Strategy & Execution</h2>
        <p class="text-zinc-500 text-lg italic">Distilling product mental models from real-world systems.</p>
      </div>
      <a href="https://medium.com/@rello4585" target="_blank" class="text-blue-400 text-sm font-bold hover:underline hidden sm:block">All Writing →</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {homePageContent.strategyPieces.map((piece) => (
        <a href={piece.url} target="_blank" class="group block p-8 bg-zinc-900/50 border border-white/5 rounded-3xl hover:border-blue-500/30 transition-all hover:scale-[1.02] hover:shadow-xl hover:shadow-blue-900/10">
          <h3 class="text-xl font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">{piece.title}</h3>
          <p class="text-emerald-400/80 text-sm font-medium mb-4">{piece.subtitle}</p>
          <p class="text-zinc-400 text-sm mb-6 leading-relaxed line-clamp-2">{piece.description}</p>
          
          <div class="space-y-3 pt-4 border-t border-white/5">
            <div class="text-xs">
              <span class="text-blue-400/80 font-bold uppercase tracking-wider mr-2">Core Mental Model:</span>
              <span class="text-zinc-300">{piece.mentalModel}</span>
            </div>
            <div class="text-xs">
              <span class="text-emerald-400/80 font-bold uppercase tracking-wider mr-2">Success Metric:</span>
              <span class="text-zinc-300">{piece.successMetric}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
    <a href="https://medium.com/@rello4585" target="_blank" class="text-blue-400 text-sm font-bold hover:underline sm:hidden mt-8 block">All Writing →</a>
  </section>

  {/* 9. CONTACT */}
  <section class="max-w-4xl mx-auto px-6 pb-32 opacity-0 translate-y-4 animate-[fade-in_0.8s_ease-out_0.9s_forwards]">
    <h2 class="font-bold text-3xl text-white mb-2">Get in Touch</h2>
    <div class="mb-10 text-zinc-400 text-lg">
      <Fragment set:html={connectDescription} />
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {aboutPageContent.connect.links.map((item) => (
        <SocialLinkBox {...item} />
      ))}
    </div>
  </section>
</Layout>

<style is:global>
  @keyframes fade-in {
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
