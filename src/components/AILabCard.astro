---
import { Icon } from "astro-icon/components";
import type { AILab } from "../types/config";

type Props = AILab;

const { name, description, takeaway, tags, url, ctaLabel } = Astro.props;
const buttonLabel = ctaLabel ?? 'View Experiment';
const isHub = tags.includes('Experiment Hub');
---

<a href={url} target="_blank" rel="noopener noreferrer" class={`block group relative p-6 bg-zinc-900/50 border rounded-3xl transition-all hover:scale-105 hover:shadow-xl ${isHub ? 'border-teal-500/30 hover:border-teal-400/50 hover:shadow-teal-900/20' : 'border-white/5 hover:border-emerald-500/30 hover:shadow-emerald-900/10'} hover:bg-zinc-900/80`}>
  <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
  <div class="relative z-10">
    <div class="flex items-center justify-between mb-6">
      <div class={`w-12 h-12 flex items-center justify-center rounded-2xl bg-black/40 border shrink-0 transition-colors ${isHub ? 'border-teal-500/30 group-hover:border-teal-400/50' : 'border-white/10 group-hover:border-emerald-500/30'}`}>
        <Icon name={isHub ? 'mdi:beaker-outline' : 'mdi:flask-outline'} width={24} height={24} class={isHub ? 'text-teal-400' : 'text-emerald-400'} />
      </div>
      <div class="flex flex-wrap gap-2 justify-end">
        {tags.map((tag) => (
          <span class={`px-2 py-1 rounded text-[10px] font-bold uppercase tracking-widest border ${
            tag === 'Experiment Hub'
              ? 'bg-teal-500/10 text-teal-400 border-teal-500/30'
              : 'bg-zinc-800 text-zinc-400 border-zinc-700'
          }`}>{tag}</span>
        ))}
      </div>
    </div>
    
    <h3 class={`text-xl font-bold text-white mb-2 transition-colors ${isHub ? 'group-hover:text-teal-400' : 'group-hover:text-emerald-400'}`}>{name}</h3>
    <p class="text-zinc-500 text-xs font-bold uppercase tracking-widest mb-1 mt-4">Description</p>
    <p class="text-sm text-zinc-300 mb-4 leading-relaxed line-clamp-2">{description}</p>
    
    <p class="text-zinc-500 text-xs font-bold uppercase tracking-widest mb-1">Takeaway</p>
    <p class="text-sm text-emerald-400/80 mb-6 leading-relaxed line-clamp-2 italic">{takeaway}</p>
    
    <div class={`flex items-center text-xs font-bold uppercase tracking-widest gap-2 transition-colors ${isHub ? 'text-teal-500/70 group-hover:text-teal-400' : 'text-emerald-500/70 group-hover:text-emerald-400'}`}>
      {buttonLabel}
      <Icon name="mdi:arrow-right" class="group-hover:translate-x-1 transition-transform" />
    </div>
  </div>
</a>
