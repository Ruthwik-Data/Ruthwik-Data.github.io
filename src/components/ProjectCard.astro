---
import { Icon } from "astro-icon/components";
import type { Project } from "../types/config";

type Props = Project;

const { id, title, metric, status, category, shortProblem, shortSolution, outcome, githubUrl, liveUrl, galleryUrls, image } = Astro.props;

const thumbnail = galleryUrls && galleryUrls.length > 0 ? galleryUrls[0] : image;
---

<div class="group relative flex flex-col justify-between p-6 bg-zinc-900 border border-white/5 rounded-3xl hover:border-blue-500/30 transition-all hover:scale-[1.02] hover:shadow-xl hover:shadow-blue-900/10 hover:bg-zinc-800/50 h-full">
  <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
  
  <div class="relative z-10 flex-1 flex flex-col">
    <a href={`/projects/${id}`} class="block w-full aspect-[2/1] rounded-2xl overflow-hidden mb-6 border border-white/5 bg-zinc-950 relative group/img focus:outline-none focus:ring-2 focus:ring-blue-500/50">
      <img src={thumbnail} alt={`${title} Thumbnail`} loading="lazy" class="w-full h-full object-cover group-hover/img:scale-105 group-hover:scale-[1.03] transition-transform duration-700" onerror="this.style.opacity='0.2'" />
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-900/80 via-transparent to-transparent opacity-60"></div>
    </a>
    
    <div class="flex items-center justify-between mb-2">
      <span class={`px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-widest ${
        category === 'Shipped Product' ? 'bg-emerald-500/10 text-emerald-400' :
        category === 'Product Thinking' ? 'bg-blue-500/10 text-blue-400' :
        'bg-purple-500/10 text-purple-400'
      }`}>
        {category}
      </span>
      
      <span class={`flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-widest ${
        status === 'Live' ? 'text-emerald-400' : 
        status === 'Prototype' ? 'text-blue-400' : 
        'text-purple-400'
      }`}>
        <span class={`w-1.5 h-1.5 rounded-full ${
          status === 'Live' ? 'bg-emerald-400 animate-pulse' : 
          status === 'Prototype' ? 'bg-blue-400' : 
          'bg-purple-400'
        }`}></span>
        {status}
      </span>
    </div>
    
    <h3 class="text-2xl font-bold text-white mb-6 group-hover:text-blue-400 transition-colors">{title}</h3>
    
    <div class="space-y-4 mb-8 flex-1">
      <div>
        <h4 class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest mb-1">Problem</h4>
        <p class="text-[13px] text-zinc-400 leading-relaxed">{shortProblem}</p>
      </div>
      <div>
        <h4 class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest mb-1">Solution</h4>
        <p class="text-[13px] text-zinc-400 leading-relaxed">{shortSolution}</p>
      </div>
      <div>
        <h4 class="text-[10px] text-emerald-500/80 font-bold uppercase tracking-widest mb-1">Outcome</h4>
        <p class="text-[13px] text-emerald-400/90 leading-relaxed font-medium">{outcome}</p>
      </div>
      {metric && (
        <div class="pt-2 border-t border-white/5">
          <span class="inline-flex items-center gap-1.5 text-[11px] font-bold text-amber-400/90 bg-amber-500/10 border border-amber-500/20 px-3 py-1 rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {metric}
          </span>
        </div>
      )}
    </div>
  </div>
  
  <div class="relative z-10 flex flex-wrap gap-2 mt-auto pt-4 border-t border-white/5">
    <a href={`/projects/${id}`} class="flex-1 px-4 py-2 bg-blue-600/10 hover:bg-blue-600 hover:text-white text-blue-400 border border-blue-600/20 hover:border-blue-600 rounded-full text-[11px] font-bold text-center transition-all flex justify-center items-center gap-1.5">
      View Case Study
      <Icon name="mdi:arrow-right" class="w-3 h-3 group-hover:translate-x-1 transition-transform" />
    </a>
    
    {liveUrl && (
      <a href={liveUrl} target="_blank" class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 border border-white/5 hover:border-white/20 rounded-full text-[11px] font-bold text-white text-center transition-all flex justify-center items-center gap-1.5">
        <Icon name="mdi:web" class="w-3 h-3" />
        Live
      </a>
    )}
    
    {githubUrl && (
      <a href={githubUrl} target="_blank" class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 border border-white/5 hover:border-white/20 rounded-full text-[11px] font-bold text-white text-center transition-all flex justify-center items-center gap-1.5">
        <Icon name="mdi:github" class="w-3 h-3" />
        GitHub
      </a>
    )}
  </div>
</div>
